# ============================================================
# Gmail 邮箱前缀检测 —— 账号凭据样例
# ============================================================
# 复制本文件为 .env,填入你自己的真实凭据:
#   cp .env.example .env   (Windows: copy .env.example .env)
#
# 获取凭据的两种方式(任选其一):
#
# 【方式 A:Python 脚本自动解析 curl(推荐)】
#   1. 浏览器登录账号 → myaccount.google.com「个人信息→邮箱地址」修改页
#   2. 邮箱输入框打个字触发检查请求 → 浏览器 DevTools 抓到 chspYe 那条
#   3. 右键 Copy as cURL (bash) → 存成 template.txt
#   4. 运行:python check_gmail_alias.py --import-curl main -f template.txt
#      → 打印出的片段直接粘进 .env(覆盖下面 MAIN_* 即可)
#
# 【方式 B:浏览器控制台】
#   打开修改邮箱页 → F12 Console → 粘 console_export_env.js
#   (注意:超长 cURL 在 prompt 框可能被截断,推荐用方式 A)
#
# 多账号:再复制一组,前缀换成 WORK / PERSONAL 等,用 --account 切换。
# ============================================================

# ── 账号 MAIN(主账号示例)──
MAIN_U=0
MAIN_FSID=1234567890123456789
MAIN_BL=boq_identityaccountsettingsuiserver_20260622.07_p0
MAIN_RAPT=AEjHL4X_在这里填_rapt_参数_很长一串
MAIN_AT=ADbtGJxxxxxx:1782403015119
MAIN_COOKIE=SID=g.a000_填你的SID; __Secure-1PSID=g.a000_填你的; __Secure-1PSIDTS=sidts-填你的PSIDTS; HSID=填你的; SSID=填你的; APISID=填你的; SAPISID=填你的; SIDCC=填你的

# ── 账号 WORK(第二账号示例,可选)──
# WORK_U=3
# WORK_FSID=...
# WORK_BL=...
# WORK_RAPT=...
# WORK_AT=...
# WORK_COOKIE=...
